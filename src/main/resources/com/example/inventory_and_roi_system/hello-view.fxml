<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<TabPane tabClosingPolicy="UNAVAILABLE" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/19"
         fx:controller="com.example.inventory_and_roi_system.controllers.HelloController">
    <tabs>
        <Tab text="Active Inventory">
            <VBox alignment="CENTER" spacing="15.0">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

                <Label text="Inventory Tracker">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>

                <HBox alignment="CENTER" spacing="10.0">
                    <TextField fx:id="nameInput" promptText="Product Name" prefWidth="200.0" />
                    <TextField fx:id="qtyInput" promptText="Qty" prefWidth="60.0" />
                    <TextField fx:id="costInput" promptText="Cost/Box" prefWidth="100.0" />
                    <TextField fx:id="saleInput" promptText="Sale Price" prefWidth="100.0" />
                    <Button onAction="#onAddClick" text="Add Product"
                            style="-fx-background-color: #2b67f2; -fx-text-fill: white; -fx-font-weight: bold;"/>

                    <ToggleButton fx:id="simToggle" text="Simulation: OFF" onAction="#handleToggleSimulation"
                                  style="-fx-background-color: #7d7d7d; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>

                <TableView fx:id="inventoryTable" onMouseClicked="#handleTableClick" prefHeight="300.0" prefWidth="1050.0">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="nameCol" text="Product Name (Double-Click to Sell)" />
                        <TableColumn fx:id="qtyCol" text="Qty" />
                        <TableColumn fx:id="costCol" text="Cost/Box" />
                        <TableColumn fx:id="totalCostCol" text="Total Cost" />
                        <TableColumn fx:id="salePriceCol" text="Est. Sale Price (Ea)" />
                        <TableColumn fx:id="totalSaleCol" text="Total Potential Sale" />
                        <TableColumn fx:id="profitCol" text="Exp. Profit" />
                        <TableColumn fx:id="roiCol" text="ROI %" />
                    </columns>
                </TableView>

                <Label text="Portfolio Value Summary">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <TableView fx:id="valueTable" prefHeight="65.0" prefWidth="1050.0">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="totalPortfolioCostCol" text="Total Cost" />
                        <TableColumn fx:id="totalPortfolioSaleCol" text="Total Potential Sale" />
                        <TableColumn fx:id="totalPortfolioProfitCol" text="Total Expected Profit" />
                        <TableColumn fx:id="totalPortfolioROICol" text="Overall ROI %" />
                    </columns>
                </TableView>

                <Button onAction="#onSaveClick" text="Save Inventory to File"
                        style="-fx-background-color: #1e8a2a; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;"/>
            </VBox>
        </Tab>

        <Tab text="Sale Log &amp; History">
            <VBox alignment="CENTER" spacing="15.0">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                <Label text="Completed Sales Log"><font><Font name="System Bold" size="22.0" /></font></Label>
                <TableView fx:id="saleLogTable" prefHeight="300.0" prefWidth="1050.0">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="saleDateCol" text="Date Sold" />
                        <TableColumn fx:id="saleNameCol" text="Product Name" />
                        <TableColumn fx:id="saleQtyCol" text="Qty Sold" />
                        <TableColumn fx:id="saleCostPerCol" text="Cost / Box" />
                        <TableColumn fx:id="saleTotalCostCol" text="Total Cost" />
                        <TableColumn fx:id="salePricePerCol" text="Actual Sale Price (Ea)" />
                        <TableColumn fx:id="saleTotalSaleCol" text="Total Revenue" />
                        <TableColumn fx:id="saleActualProfitCol" text="Actual Profit" />
                        <TableColumn fx:id="saleROICol" text="ROI %" />
                    </columns>
                </TableView>
                <Label text="Sales Performance Summary"><font><Font name="System Bold" size="18.0" /></font></Label>
                <TableView fx:id="saleSummaryTable" prefHeight="65.0" prefWidth="1050.0">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="totalSoldCostCol" text="Total Cost" />
                        <TableColumn fx:id="totalSoldRevenueCol" text="Total Revenue" />
                        <TableColumn fx:id="totalActualProfitCol" text="Total Profit" />
                        <TableColumn fx:id="totalActualROICol" text="Total ROI %" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </tabs>
</TabPane>